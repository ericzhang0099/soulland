# 算力网关服务配置
NODE_ENV=development
PORT=3001

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/genloop
REDIS_URL=redis://localhost:6379

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ENABLED=true
OPENAI_PRIORITY=1

# Claude配置
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_ENABLED=true
ANTHROPIC_PRIORITY=2

# 国产大模型配置（可选）
# 阿里云百炼
ALIYUN_API_KEY=your-aliyun-api-key
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_ENABLED=false
ALIYUN_PRIORITY=3

# 智谱AI
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_ENABLED=false
ZHIPU_PRIORITY=4

# 熔断器配置
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=30000
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=3

# 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# AGC积分配置（与主系统集成）
AGC_API_URL=http://localhost:3000/api/v1
AGC_API_KEY=your-agc-service-api-key