# GenLoop API 环境变量
NODE_ENV=development
PORT=3001

# 前端URL
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# 支付宝配置 (沙箱环境)
ALIPAY_APP_ID=2024xxxxxx
ALIPAY_APP_PRIVATE_KEY=your_private_key_here
ALIPAY_PUBLIC_KEY=your_alipay_public_key_here
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_CHARSET=utf-8
ALIPAY_NOTIFY_URL=http://localhost:3001/api/payment/alipay/callback
ALIPAY_RETURN_URL=http://localhost:3000/payment/callback
ALIPAY_SANDBOX=true

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=genloop
DB_USER=root
DB_PASSWORD=password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 区块链配置
RPC_URL=https://sepolia.infura.io/v3/demo
PRIVATE_KEY=your_wallet_private_key
ALIPAY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# JWT配置
JWT_SECRET=genloop_jwt_secret_dev_2024
