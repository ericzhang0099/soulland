# GenLoop 3.0 环境变量配置

# 区块链配置
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_private_key_here

# 合约地址（部署后自动填充）
IDENTITY_NFT_ADDRESS=
INSTRUCTOR_NFT_ADDRESS=
EVOLUTION_NFT_ADDRESS=
AGC_TOKEN_ADDRESS=
GENLOOP30_CORE_ADDRESS=
GENE_TOKEN_ADDRESS=
GENE_REGISTRY_ADDRESS=
GENE_EXCHANGE_ADDRESS=

# 数据库配置
DATABASE_URL=postgresql://genloop:genloop123@localhost:5432/genloop
REDIS_URL=redis://localhost:6379

# JWT配置
JWT_SECRET=your_jwt_secret_here

# API配置
PORT=3001
API_URL=http://localhost:3001

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_IDENTITY_NFT_ADDRESS=
NEXT_PUBLIC_AGC_TOKEN_ADDRESS=

# 训练模块配置
TRAINING_API_URL=http://localhost:3001
CUDA_VISIBLE_DEVICES=0
